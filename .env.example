# Copy to .env and fill in.

# Black Forest Labs — FLUX image generation (employee headshots, product shots, logo)
# Sign up at https://api.bfl.ai/ → keys: bfl_xxx...
BFL_API_KEY=

# Optional overrides
# FLUX_MODEL=flux-pro-1.1           # or flux-dev, flux-schnell
# FLUX_OUTPUT_DIR=images/generated  # where to write generated images

# Target Odoo for scripts/setup_readonly.py (read-only tiers + demo user).
# Point at the universe's Odoo; use an Administrator user's API key.
# See scripts/readonly-accounts.md.
ODOO_URL=https://bean-forge.cloudpepper.site
ODOO_DB=bean-forge
ODOO_LOGIN=admin
ODOO_API_KEY=
